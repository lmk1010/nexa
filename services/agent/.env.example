# nexa Agent — local env example (never commit real secrets)

# Service
SERVICE_NAME=nexa-agent
SERVICE_PORT=48091
CORS_ALLOW_ORIGIN=*

# NeoX / LLM
AGENT_USE_MOCK=true
AGENT_MODEL=deepseek-chat
AGENT_PROVIDER=deepseek
# AGENT_BASE_URL=
# AGENT_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Tools
AGENT_ENABLE_INTERNAL_HTTP_TOOLS=true
AGENT_ENABLE_TOOL_SEARCH=true

# Gateway / OA (read APIs)
# KYX_GATEWAY_URL=http://127.0.0.1:48080
# OA_API_BASE_URL=http://127.0.0.1:48080
# INTERNAL_API_BASE_URL=http://127.0.0.1:48080

# Ordersys read APIs
# ORDERSYS_API_BASE_URL=

# Service account (optional, when user token missing)
# SERVICE_ACCOUNT_ENABLED=false
# OA_SERVICE_ACCOUNT_USERNAME=
# OA_SERVICE_ACCOUNT_PASSWORD=

# Warehouse (prefer RO account filled by cdc-mysql)
# OPS_WH_HOST=127.0.0.1
# OPS_WH_PORT=3306
# OPS_WH_USER=bi_ro
# OPS_WH_PASS=
# OPS_WH_DB=ordersys_dw

# Go data-center (export platform)
# NEXA_DATA_CENTER_URL=http://127.0.0.1:48092

# CDC ops probe (optional)
# OPS_CDC_HOST=127.0.0.1
# OPS_CDC_HTTP_PORT=6060

# === Nexa enterprise assistant (Go backends via gateway) ===
# Prefer single gateway entry for tools
NEXA_GATEWAY_URL=http://127.0.0.1:48080
KYX_GATEWAY_URL=http://127.0.0.1:48080
OA_API_BASE_URL=http://127.0.0.1:48080
INTERNAL_API_BASE_URL=http://127.0.0.1:48080
NEXA_DATA_CENTER_URL=http://127.0.0.1:48092
