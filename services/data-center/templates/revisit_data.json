{
  "id": "revisit_data",
  "label": "回访数据",
  "category": "订单",
  "description": "订单明细 · 含回访 / 打款人 + 差价, 按回访/打款时间过滤",
  "icon": "verified",
  "color": "#10B981",
  "max_rows": 50000,
  "visibility": {
    "allow_all_logged": true
  },
  "filters": {
    "hf_date": {
      "type": "range",
      "col": "t.hf_time",
      "required": true,
      "label": "回访时间"
    },
    "state": {
      "type": "in",
      "col": "t.state",
      "enum": "OrderState",
      "label": "订单状态"
    },
    "dept_id": {
      "type": "in",
      "col": "d_pd.dept_id",
      "label": "对接组",
      "enum": "Dept"
    },
    "province": {
      "type": "in",
      "col": "SUBSTRING_INDEX(t.region_path_str, ',', 1)",
      "enum": "Province",
      "label": "省份"
    },
    "date": {
      "type": "range",
      "col": "t.create_time",
      "label": "下单时间"
    },
    "install_date": {
      "type": "range",
      "col": "t.install_time",
      "label": "安装时间"
    },
    "pd_date": {
      "type": "range",
      "col": "t.pd_time",
      "label": "派单时间"
    },
    "dk_date": {
      "type": "range",
      "col": "t.dk_time",
      "label": "打款时间"
    },
    "seller": {
      "type": "lookup",
      "col": "t.s_uid",
      "lookup": "sellers",
      "label": "卖家（可搜索）"
    },
    "shop": {
      "type": "lookup",
      "col": "t.shop_id",
      "lookup": "shops",
      "label": "门店/网点（可搜索）"
    }
  },
  "sort": [
    "t.hf_time DESC"
  ],
  "sql": "SELECT t.source_id AS source_id, t.install_time AS install_time, t.order_no AS order_no, IFNULL(t.platform,'') AS platform, IFNULL(t.old_info,'') AS old_info, IFNULL(o.name,'') AS shop_name, t.create_time AS create_time, IFNULL(s.name,'') AS seller_name, IFNULL(t.info,'') AS store_name, IFNULL(d_pd.dept_name,'') AS dept_name, IFNULL(t.project_ids,'') AS project_ids, t.state AS state, IFNULL(t.total,0) AS total, IFNULL(t.install_price,0) AS install_price, (IFNULL(t.total,0) - IFNULL(t.install_price,0)) AS diff_price, IFNULL(u_pd.name,'') AS pd_name, t.pd_time AS pd_time, IFNULL(u_hf.name,'') AS hf_name, t.hf_time AS hf_time, IFNULL(u_cw.name,'') AS cw_name, t.dk_time AS dk_time, IFNULL(u_dev.name,'') AS dev_name FROM t_order t LEFT JOIN sys_seller s ON s.user_id = t.s_uid LEFT JOIN outlets_shop o ON o.id = t.shop_id LEFT JOIN sys_user u_pd ON u_pd.user_id = t.pd_uid LEFT JOIN sys_user u_hf ON u_hf.user_id = t.hf_uid LEFT JOIN sys_user u_cw ON u_cw.user_id = t.cw_uid LEFT JOIN sys_user u_dev ON u_dev.user_id = t.cd_uid LEFT JOIN sys_dept d_pd ON d_pd.dept_id = u_pd.dept_id WHERE t.deleted = 0 AND {WHERE}",
  "columns": [
    {
      "header": "订单来源",
      "field": "source_id",
      "width": 10,
      "enum": "OrderSource"
    },
    {
      "header": "安装时间",
      "field": "install_time",
      "width": 20,
      "type": "datetime"
    },
    {
      "header": "订单号",
      "field": "order_no",
      "width": 22
    },
    {
      "header": "所属平台",
      "field": "platform",
      "width": 12
    },
    {
      "header": "订单信息(原)",
      "field": "old_info",
      "width": 40
    },
    {
      "header": "店铺名称",
      "field": "shop_name",
      "width": 22
    },
    {
      "header": "下单时间",
      "field": "create_time",
      "width": 20,
      "type": "datetime"
    },
    {
      "header": "卖家名称",
      "field": "seller_name",
      "width": 22
    },
    {
      "header": "门店名称",
      "field": "store_name",
      "width": 22
    },
    {
      "header": "对接组",
      "field": "dept_name",
      "width": 14
    },
    {
      "header": "施工项目",
      "field": "project_ids",
      "width": 18,
      "type": "project"
    },
    {
      "header": "订单状态",
      "field": "state",
      "width": 10,
      "enum": "OrderState"
    },
    {
      "header": "价格",
      "field": "total",
      "width": 8,
      "type": "number"
    },
    {
      "header": "安装价格",
      "field": "install_price",
      "width": 10,
      "type": "number"
    },
    {
      "header": "差价",
      "field": "diff_price",
      "width": 8,
      "type": "number"
    },
    {
      "header": "派单客服",
      "field": "pd_name",
      "width": 18
    },
    {
      "header": "派单时间",
      "field": "pd_time",
      "width": 20,
      "type": "datetime"
    },
    {
      "header": "回访客服",
      "field": "hf_name",
      "width": 18
    },
    {
      "header": "回访时间",
      "field": "hf_time",
      "width": 20,
      "type": "datetime"
    },
    {
      "header": "打款客服",
      "field": "cw_name",
      "width": 18
    },
    {
      "header": "打款时间",
      "field": "dk_time",
      "width": 20,
      "type": "datetime"
    },
    {
      "header": "开发人",
      "field": "dev_name",
      "width": 16
    }
  ],
