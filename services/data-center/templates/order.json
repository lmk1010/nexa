{
  "id": "order",
  "label": "订单明细（按下单时间）",
  "category": "订单",
  "description": "订单明细通用模板 · 按下单时间过滤，支持卖家/店铺/来源/状态多维筛选",
  "icon": "receipt_long",
  "color": "#4C6EF5",
  "max_rows": 50000,
  "visibility": {
    "allow_all_logged": true
  },
  "filters": {
    "date": {
      "type": "range",
      "col": "t.create_time",
      "required": true,
      "label": "下单时间"
    },
    "state": {
      "type": "in",
      "col": "t.state",
      "enum": "OrderState",
      "label": "订单状态"
    },
    "source": {
      "type": "in",
      "col": "t.source_id",
      "enum": "OrderSource",
      "label": "订单来源"
    },
    "platform": {
      "type": "like",
      "col": "t.platform",
      "label": "店铺来源（模糊，如 TTS/京东旗舰店）"
    },
    "region": {
      "type": "like",
      "col": "t.region_path_str",
      "label": "区域关键字（模糊，如 合肥/瑶海区）"
    },
    "dept_id": {
      "type": "in",
      "col": "u.dept_id",
      "label": "派单部门",
      "enum": "Dept"
    },
    "province": {
      "type": "in",
      "col": "SUBSTRING_INDEX(t.region_path_str, ',', 1)",
      "enum": "Province",
      "label": "省份"
    },
    "pd_date": {
      "type": "range",
      "col": "t.pd_time",
      "label": "派单时间"
    },
    "install_date": {
      "type": "range",
      "col": "t.install_time",
      "label": "安装时间"
    },
    "hf_date": {
      "type": "range",
      "col": "t.hf_time",
      "label": "回访时间"
    },
    "dk_date": {
      "type": "range",
      "col": "t.dk_time",
      "label": "打款时间"
    },
    "seller": {
      "type": "lookup",
      "col": "t.s_uid",
      "lookup": "sellers",
      "label": "卖家（可搜索）"
    },
    "shop": {
      "type": "lookup",
      "col": "t.shop_id",
      "lookup": "shops",
      "label": "门店/网点（可搜索）"
    }
  },
  "sort": [
    "t.create_time DESC"
  ],
  "sql": "SELECT t.order_no AS order_no, IFNULL(o.name,'') AS shop_name, IFNULL(t.info,'') AS info, IFNULL(t.old_info,'') AS old_info, t.source_id AS source_id, IFNULL(t.platform,'') AS platform, t.state AS state, IFNULL(t.project_ids,'') AS project_ids, IFNULL(t.total,0) AS total, IFNULL(t.install_price,0) AS install_price, IFNULL(t.mobile,'') AS buyer_mobile, IFNULL(t.region_path_str,'') AS region_path, t.create_time AS create_time, t.pd_time AS pd_time, IFNULL(u.name,'') AS pd_name, IFNULL(d.dept_name,'') AS dept_name, IFNULL(s.name,'') AS seller_name, t.install_time AS install_time FROM t_order t LEFT JOIN sys_seller s ON s.user_id = t.s_uid LEFT JOIN outlets_shop o ON o.id = t.shop_id LEFT JOIN sys_user u ON u.user_id = t.pd_uid LEFT JOIN sys_dept d ON d.dept_id = u.dept_id WHERE t.deleted = 0 AND {WHERE}",
  "columns": [
    {
      "header": "订单编号",
      "field": "order_no",
      "width": 22
    },
    {
      "header": "网点名称",
      "field": "shop_name",
      "width": 24
    },
    {
      "header": "订单信息(新)",
      "field": "info",
      "width": 32
    },
    {
      "header": "订单信息(原)",
      "field": "old_info",
      "width": 32
    },
    {
      "header": "订单来源",
      "field": "source_id",
      "width": 10,
      "enum": "OrderSource"
    },
    {
      "header": "店铺来源",
      "field": "platform",
      "width": 18
    },
    {
      "header": "订单状态",
      "field": "state",
      "width": 10,
      "enum": "OrderState"
    },
    {
      "header": "施工项目",
      "field": "project_ids",
      "width": 20,
      "type": "project"
    },
    {
      "header": "订单总价",
      "field": "total",
      "width": 10,
      "type": "number"
    },
    {
      "header": "安装价格",
      "field": "install_price",
      "width": 10,
      "type": "number"
    },
    {
      "header": "车主手机号",
      "field": "buyer_mobile",
      "width": 14
    },
    {
      "header": "区域",
      "field": "region_path",
      "width": 22
    },
    {
      "header": "下单时间",
      "field": "create_time",
      "width": 20,
      "type": "datetime"
    },
    {
      "header": "派单时间",
      "field": "pd_time",
      "width": 20,
      "type": "datetime"
    },
    {
      "header": "派单人",
      "field": "pd_name",
      "width": 14
    },
    {
      "header": "派单部门",
      "field": "dept_name",
      "width": 14
    },
    {
      "header": "卖家名称",
      "field": "seller_name",
      "width": 20
    },
    {
      "header": "安装时间",
      "field": "install_time",
      "width": 20,
      "type": "datetime"
    }
  ],
