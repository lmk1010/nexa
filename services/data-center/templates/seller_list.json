{
  "id": "seller_list",
  "label": "卖家列表",
  "category": "卖家",
  "description": "全部卖家账号 · 含平台、类型、积分、部门",
  "icon": "shopping_bag",
  "color": "#F59E0B",
  "max_rows": 20000,
  "visibility": {
    "allow_all_logged": true
  },
  "filters": {
    "name": {
      "type": "like",
      "col": "s.name",
      "label": "卖家名称"
    },
    "user_name": {
      "type": "like",
      "col": "s.user_name",
      "label": "登录账号"
    },
    "platform": {
      "type": "in",
      "col": "s.platform",
      "enum": "SellerPlatform",
      "label": "所属平台"
    },
    "type": {
      "type": "in",
      "col": "s.type",
      "enum": "SellerType",
      "label": "卖家类型"
    },
    "dept_id": {
      "type": "in",
      "col": "s.dept_id",
      "label": "对接部门",
      "enum": "Dept"
    },
    "region": {
      "type": "like",
      "col": "s.region_path_str",
      "label": "区域关键字（模糊，如 合肥/瑶海区）"
    },
    "province": {
      "type": "in",
      "col": "SUBSTRING_INDEX(s.region_path_str, ',', 1)",
      "enum": "Province",
      "label": "省份"
    }
  },
  "sort": [
    "s.integral DESC",
    "s.user_id DESC"
  ],
  "sql": "SELECT s.user_id AS user_id, IFNULL(s.name,'') AS name, IFNULL(s.user_name,'') AS user_name, IFNULL(s.link_name,'') AS link_name, IFNULL(s.mobile,'') AS mobile, IFNULL(s.platform,'') AS platform, IFNULL(s.type,'') AS type, IFNULL(s.integral,0) AS integral, IFNULL(s.gif_integral,0) AS gif_integral, IFNULL(s.pf_integral,0) AS pf_integral, IFNULL(s.credit_integral,0) AS credit_integral, IFNULL(d.dept_name,'') AS dept_name, IFNULL(s.region_path_str,'') AS region_path, IFNULL(s.address,'') AS address FROM sys_seller s LEFT JOIN sys_dept d ON d.dept_id = s.dept_id WHERE {WHERE}",
  "columns": [
    {
      "header": "卖家ID",
      "field": "user_id",
      "width": 10,
      "type": "number"
    },
    {
      "header": "卖家名称",
      "field": "name",
      "width": 26
    },
    {
      "header": "登录账号",
      "field": "user_name",
