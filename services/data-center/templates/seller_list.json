      "enum": "SellerPlatform"
    },
    {
      "header": "卖家类型",
      "field": "type",
      "width": 14,
      "enum": "SellerType"
    },
    {
      "header": "可用积分",
      "field": "integral",
      "width": 12,
      "type": "number"
    },
    {
      "header": "赠送积分",
      "field": "gif_integral",
      "width": 12,
      "type": "number"
    },
    {
      "header": "赔付积分",
