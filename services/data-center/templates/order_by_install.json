{
  "id": "order_by_install",
  "label": "订单明细（按安装时间）",
  "category": "订单",
  "description": "订单明细 · 按安装时间过滤（施工统计/门店结算/售后回溯常用）",
  "icon": "handyman",
  "color": "#0EA5E9",
  "max_rows": 50000,
  "visibility": {
    "allow_all_logged": true
  },
  "filters": {
    "install_date": {
      "type": "range",
      "col": "t.install_time",
      "required": true,
      "label": "安装时间"
    },
    "state": {
      "type": "in",
      "col": "t.state",
      "enum": "OrderState",
      "label": "订单状态"
    },
    "source": {
      "type": "in",
      "col": "t.source_id",
      "enum": "OrderSource",
      "label": "订单来源"
    },
    "platform": {
      "type": "like",
      "col": "t.platform",
      "label": "店铺来源"
    },
    "region": {
      "type": "like",
      "col": "t.region_path_str",
      "label": "区域关键字（模糊，如 合肥/瑶海区）"
    },
    "province": {
      "type": "in",
      "col": "SUBSTRING_INDEX(t.region_path_str, ',', 1)",
      "enum": "Province",
      "label": "省份"
    },
    "date": {
      "type": "range",
      "col": "t.create_time",
      "label": "下单时间"
    },
    "pd_date": {
      "type": "range",
      "col": "t.pd_time",
      "label": "派单时间"
    },
    "hf_date": {
      "type": "range",
      "col": "t.hf_time",
      "label": "回访时间"
    },
    "dk_date": {
      "type": "range",
      "col": "t.dk_time",
      "label": "打款时间"
    },
    "seller": {
      "type": "lookup",
      "col": "t.s_uid",
      "lookup": "sellers",
      "label": "卖家（可搜索）"
    },
    "shop": {
      "type": "lookup",
      "col": "t.shop_id",
      "lookup": "shops",
      "label": "门店/网点（可搜索）"
    }
  },
  "sort": [
    "t.install_time DESC"
  ],
  "sql": "SELECT t.order_no AS order_no, IFNULL(o.name,'') AS shop_name, IFNULL(t.js_mobile,'') AS installer_mobile, IFNULL(t.info,'') AS info, t.source_id AS source_id, IFNULL(t.platform,'') AS platform, t.state AS state, IFNULL(t.project_ids,'') AS project_ids, IFNULL(t.total,0) AS total, IFNULL(t.install_price,0) AS install_price, (IFNULL(t.total,0) - IFNULL(t.install_price,0)) AS diff_price, IFNULL(t.region_path_str,'') AS region_path, t.install_time AS install_time, t.create_time AS create_time, IFNULL(s.name,'') AS seller_name, IFNULL(u.name,'') AS pd_name FROM t_order t LEFT JOIN sys_seller s ON s.user_id = t.s_uid LEFT JOIN outlets_shop o ON o.id = t.shop_id LEFT JOIN sys_user u ON u.user_id = t.pd_uid WHERE t.deleted = 0 AND t.install_time IS NOT NULL AND {WHERE}",
  "columns": [
    {
      "header": "订单编号",
      "field": "order_no",
      "width": 22
    },
    {
      "header": "网点名称",
      "field": "shop_name",
      "width": 24
    },
    {
      "header": "施工人电话",
      "field": "installer_mobile",
      "width": 14
    },
    {
      "header": "订单信息",
      "field": "info",
      "width": 32
    },
    {
      "header": "订单来源",
      "field": "source_id",
      "width": 10,
      "enum": "OrderSource"
    },
    {
      "header": "店铺来源",
      "field": "platform",
      "width": 18
    },
    {
      "header": "订单状态",
      "field": "state",
      "width": 10,
      "enum": "OrderState"
    },
    {
      "header": "施工项目",
      "field": "project_ids",
      "width": 20,
      "type": "project"
    },
    {
      "header": "订单总价",
      "field": "total",
      "width": 10,
      "type": "number"
    },
    {
      "header": "安装价格",
      "field": "install_price",
      "width": 10,
      "type": "number"
    },
    {
      "header": "差价",
      "field": "diff_price",
      "width": 10,
      "type": "number"
    },
    {
      "header": "区域",
      "field": "region_path",
      "width": 22
    },
    {
      "header": "安装时间",
      "field": "install_time",
      "width": 20,
      "type": "datetime"
    },
    {
      "header": "下单时间",
      "field": "create_time",
      "width": 20,
      "type": "datetime"
    },
    {
      "header": "卖家名称",
      "field": "seller_name",
      "width": 20
    },
    {
      "header": "派单人",
      "field": "pd_name",
      "width": 14
    }
  ],
  "enums": {
    "OrderState": {
      "-11": "退回给卖家",
      "-2": "网点拒单",
      "-1": "派单已撤单",
      "0": "未派单",
      "1": "已派单",
      "2": "已接单",
      "3": "已安装",
      "4": "回访完成",
      "5": "已完结",
      "6": "申请撤单",
      "7": "已撤单",
      "22": "补发",
      "401": "待打款",
      "2222": "有售后"
    },
    "OrderSource": {
      "1": "淘宝",
      "2": "京东",
      "3": "天猫工单",
      "4": "天猫",
      "5": "合作平台",
      "6": "京东非自营有价格",
      "7": "拼多多",
      "8": "抖音",
      "9": "京东自营"
    },
    "Province": {
      "上海市": "上海市",
      "云南省": "云南省",
      "内蒙古自治区": "内蒙古",
      "北京市": "北京市",
      "吉林省": "吉林省",
      "四川省": "四川省",
      "天津市": "天津市",
      "宁夏回族自治区": "宁夏",
      "安徽省": "安徽省",
      "山东省": "山东省",
      "山西省": "山西省",
      "广东省": "广东省",
      "广西壮族自治区": "广西",
      "新疆维吾尔自治区": "新疆",
      "江苏省": "江苏省",
      "江西省": "江西省",
      "河北省": "河北省",
      "河南省": "河南省",
      "浙江省": "浙江省",
      "海南省": "海南省",
      "湖北省": "湖北省",
      "湖南省": "湖南省",
      "甘肃省": "甘肃省",
      "福建省": "福建省",
      "西藏自治区": "西藏",
      "贵州省": "贵州省",
      "辽宁省": "辽宁省",
      "重庆市": "重庆市",
