<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kyx.service.bpm.dal.mysql.definition.BpmProcessDefinitionInfoMapper">

    <!--
        查询当前租户可见的流程定义列表（支持跨租户）

        查询逻辑：
        1. 当前租户的流程（tenant_id = #{tenantId} AND cross_tenant_mode = 0）
        2. 全局可见的流程（cross_tenant_mode = 1）
        3. 指定租户可见且包含当前租户的流程（cross_tenant_mode = 2 AND FIND_IN_SET(#{tenantId}, visible_tenant_ids)）
    -->
    <select id="selectVisibleList" resultType="com.kyx.service.bpm.dal.dataobject.definition.BpmProcessDefinitionInfoDO">
        SELECT *
        FROM bpm_process_definition_info
        WHERE deleted = 0
          AND (
            <!-- 情况1：当前租户的流程（租户隔离模式） -->
            (tenant_id = #{tenantId} AND (cross_tenant_mode = 0 OR cross_tenant_mode IS NULL))

            <!-- 情况2：全局可见的流程 -->
            OR (cross_tenant_mode = 1)

            <!-- 情况3：指定租户可见且包含当前租户 -->
            OR (cross_tenant_mode = 2 AND FIND_IN_SET(#{tenantId}, visible_tenant_ids) > 0)
        )
        ORDER BY sort ASC, create_time DESC
    </select>

</mapper>
